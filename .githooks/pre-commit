#!/usr/bin/env python
"""
GROUP-89 流出防止 pre-commit hook：staged diff の追加行に開発者間やり取り・指示引用を検出。

git diff --cached --no-color の出力を parse し、`+` で始まる追加行のみを LEAK_PATTERNS で走査。
検出時は exit 1 で commit を block。bypass 環境変数 BORGESTAG_LEAK_BYPASS=1 で skip。
"""
import sys
import os
import subprocess

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _leak_patterns import LEAK_PATTERNS


def main():
    if os.environ.get("BORGESTAG_LEAK_BYPASS") == "1":
        return 0

    try:
        result = subprocess.run(
            ["git", "diff", "--cached", "--no-color", "--unified=0"],
            capture_output=True, text=True, encoding="utf-8", errors="replace",
        )
    except Exception as e:
        print(f"[pre-commit] git diff failed (skip): {e}", file=sys.stderr)
        return 0
    if result.returncode != 0:
        print(f"[pre-commit] git diff returned {result.returncode} (skip)", file=sys.stderr)
        return 0

    diff = result.stdout

    # parse: + で始まる追加行のみ抽出（+++ ヘッダは除外）
    # exclude：.githooks/ 配下（hook 定義ファイル自身は流出 regex を含むため scan 対象外）
    EXCLUDED_PREFIXES = (".githooks/",)
    current_file = None
    hits = []
    for line in diff.split("\n"):
        if line.startswith("+++ b/"):
            current_file = line[6:].strip()
            continue
        if line.startswith("+++"):
            current_file = line[4:].strip()
            continue
        if line.startswith("diff --git"):
            continue
        if current_file and any(current_file.startswith(p) for p in EXCLUDED_PREFIXES):
            continue
        if line.startswith("+") and not line.startswith("+++"):
            added = line[1:]
            for pat, label in LEAK_PATTERNS:
                for m in pat.finditer(added):
                    hits.append({
                        "file": current_file or "<unknown>",
                        "label": label,
                        "match": m.group(0),
                        "context": added.strip()[:120],
                    })

    if not hits:
        return 0

    print("ERROR: staged diff の追加行に開発者間のやり取り・指示の引用を検出（GROUP-89 流出防止 pre-commit hook）", file=sys.stderr)
    print(file=sys.stderr)
    for h in hits[:20]:
        print(f"  - {h['file']}: [{h['label']}] '{h['match']}'", file=sys.stderr)
        print(f"     ctx: {h['context']}", file=sys.stderr)
    if len(hits) > 20:
        print(f"  ... 他 {len(hits) - 20} 件", file=sys.stderr)
    print(file=sys.stderr)
    print("対応：該当箇所を中立な技術記述に書換、または環境変数 BORGESTAG_LEAK_BYPASS=1 を設定して再実行（auditable）", file=sys.stderr)
    return 1


if __name__ == "__main__":
    sys.exit(main())
