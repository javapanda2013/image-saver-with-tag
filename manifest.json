{
  "manifest_version": 2,
  "name": "BorgesTag",
  "version": "1.12.0",
  "description": "右クリックから画像をタグ付きで保存する拡張機能",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "nativeMessaging",
    "management",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    "src/modal/modal.html",
    "src/modal/modal.js"
  ],
  "background": {
    "scripts": [
      "src/background/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "BorgesTag 設定を開く",
    "default_icon": {
      "56": "icons/icon48.png",
      "112": "icons/icon96.png"
    }
  },
  "options_ui": {
    "page": "src/settings/settings.html",
    "open_in_tab": true
  },
  "icons": {
    "56": "icons/icon48.png",
    "112": "icons/icon96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "image-saver-tags@example.com",
      "strict_min_version": "109.0"
    }
  }
}
