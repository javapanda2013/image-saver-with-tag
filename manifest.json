{
  "manifest_version": 2,
  "name": "BorgesTag",
  "version": "1.45.2",
  "description": "右クリックから画像をタグ付きで保存する拡張機能",
  "content_security_policy": "script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; object-src 'self';",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "nativeMessaging",
    "management",
    "notifications",
    "clipboardWrite",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    "src/modal/modal.html",
    "src/modal/modal.js",
    "src/viewer/viewer.html",
    "src/viewer/viewer.js",
    "src/video-convert/video_convert.html",
    "src/video-convert/video_convert.js",
    "src/vendor/gifshot.min.js",
    "src/vendor/gifuct/index.js",
    "src/vendor/gifuct/deinterlace.js",
    "src/vendor/gifuct/lzw.js",
    "src/vendor/gifuct/jsBinarySchemaParser/index.js",
    "src/vendor/gifuct/jsBinarySchemaParser/parsers/uint8.js",
    "src/vendor/gifuct/jsBinarySchemaParser/schemas/gif.js",
    "src/decoders/gif-decoder.worker.js"
  ],
  "background": {
    "scripts": [
      "src/background/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "BorgesTag 設定を開く",
    "default_icon": {
      "56": "icons/icon48.png",
      "112": "icons/icon96.png"
    }
  },
  "options_ui": {
    "page": "src/settings/settings.html",
    "open_in_tab": true
  },
  "icons": {
    "56": "icons/icon48.png",
    "112": "icons/icon96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "image-saver-tags@example.com",
      "strict_min_version": "114.0"
    }
  }
}
